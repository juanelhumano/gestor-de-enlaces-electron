{
  "name": "gestor-de-enlaces-electron",
  "version": "10.11.1",
  "description": "Una aplicación de escritorio Electron para gestionar enlaces con better-sqlite3, roles de usuario y Gemini.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-builder --windows",
    "release": "electron-builder --windows --publish always"
  },
  "keywords": [
    "Electron",
    "Gestor de enlaces",
    "better-sqlite3",
    "Firebase",
    "Gemini"
  ],
  "author": "Tu Nombre",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.9",
    "firebase-admin": "^12.1.0",
    "sharp": "^0.32.6",
    "uuid": "^9.0.0",
    "@google/generative-ai": "^0.11.0"
  },
  "build": {
    "appId": "com.yourcompany.gestorEnlaces",
    "productName": "GestorDeEnlaces",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "libro.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!node_modules/electron-builder",
      "!node_modules/electron-rebuild"
    ],
    "publish": {
      "provider": "github",
      "owner": "juanelhumano",
      "repo": "gestor-de-enlaces-electron",
      "releaseType": "release",
      "draft": false
    }
  }
}
